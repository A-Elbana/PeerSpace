{
  "name": "peerspace",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:client dev:server",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "install:all": "npm install --workspaces"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
