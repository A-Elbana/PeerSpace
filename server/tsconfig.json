{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File layout
    "rootDir": ".",
    "outDir": "dist",
    // Language + module settings for Node + Prisma
    "target": "ES2023",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": [
      "ES2020"
    ],
    // Node typings
    "types": [
      "node"
    ],
    // Interop + JSON
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    // Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    // Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // Performance / compatibility
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    // Useful for many Node tools
    "isolatedModules": false
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts",
    "prisma.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}