generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator jsonSchema {
  provider = "prisma-json-schema-generator"
  output   = "../src/generated/json-schema"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
  // Assuming 'guest' is unauthenticated, we don't need it as a database role
}

enum CommunityType {
  PUBLIC
  PRIVATE
}

enum FileContext {
  POST
  SUBMISSION
  NOTE
  ASSIGNMENT
  COMMUNITY_BANNER
  USER_AVATAR
}

// Add this Enum to categorize notifications
enum NotificationType {
  ANNOUNCEMENT
  ASSIGNMENT
  SUBMISSION_GRADED
  REPLY
  SYSTEM
  TASK_INVITE
}

model ActivityLog {
  id             Int        @id @default(autoincrement())
  date           DateTime?  @db.Timestamp(6)
  associated_uid Int
  associated_cid String?    @db.Uuid
  description    String?    @db.VarChar
  action_type    Int?
  Community      Community? @relation(fields: [associated_cid], references: [id], onDelete: SetNull, onUpdate: Cascade)
  User           User       @relation(fields: [associated_uid], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([associated_uid])
  @@index([associated_cid])
  @@index([date])
}

model Admin {
  uid  Int  @id
  User User @relation(fields: [uid], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Assignment {
  id                       Int                        @id @default(autoincrement())
  title                    String                     @db.VarChar
  description              String?                    @db.VarChar
  due_date                 DateTime?                  @db.Timestamp(6)
  max_points               Float?
  canBeLate                Boolean                    @default(true)
  assigner_uid             Int
  cid                      String                     @db.Uuid
  Instructor               Instructor                 @relation(fields: [assigner_uid], references: [uid], onDelete: Cascade, onUpdate: Cascade)
  Community                Community                  @relation(fields: [cid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  AssignmentFileAttachment AssignmentFileAttachment[]
  Submission               Submission[]
  TaskAssignmentRelation   TaskAssignmentRelation[]

  @@index([cid])
  @@index([assigner_uid])
  @@index([due_date])
  @@index([cid, due_date])
}

model AssignmentFileAttachment {
  aid        Int?
  fid        String      @id @db.Uuid
  Assignment Assignment? @relation(fields: [aid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  File       File        @relation(fields: [fid], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Badge {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar
  icon_url     String         @db.VarChar
  StudentBadge StudentBadge[]
}

model Comment {
  id                 Int       @id @default(autoincrement())
  pid                Int
  content            String    @db.VarChar
  isDeleted          Boolean   @default(false)
  approved_by_inst   Boolean
  approved_by_op     Boolean
  approved_at_inst   DateTime? @db.Timestamp(6)
  approved_at_op     DateTime? @db.Timestamp(6)
  comment_date       DateTime  @db.Timestamp(6)
  commenter_uid      Int
  parent_comment_pid Int?
  parent_comment_id  Int?
  User               User      @relation(fields: [commenter_uid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Comment            Comment?  @relation("CommentToComment", fields: [parent_comment_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  other_Comment      Comment[] @relation("CommentToComment")
  Post               Post      @relation(fields: [pid], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([pid])
  @@index([commenter_uid])
  @@index([parent_comment_id])
  @@index([comment_date])
  @@index([pid, isDeleted])
}

model Community {
  id             String        @id @default(uuid()) @db.Uuid
  name           String        @db.VarChar
  description    String?       @db.VarChar
  type           CommunityType
  banner_file_id String?       @db.Uuid
  ActivityLog    ActivityLog[]
  Assignment     Assignment[]
  BannerFile     File?         @relation("CommunityBanner", fields: [banner_file_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  Enrollment     Enrollment[]
  Manages        Manages[]
  Post           Post[]
  Session        Session?

  @@index([type])
  @@index([name])
  @@index([banner_file_id])
}

model Enrollment {
  cid       String    @db.Uuid
  sid       Int
  Community Community @relation(fields: [cid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Student   Student   @relation(fields: [sid], references: [uid], onDelete: Cascade, onUpdate: Cascade)

  @@id([cid, sid])
  @@index([sid])
  @@index([cid])
}

model File {
  id          String @id @default(uuid()) @db.Uuid
  uploader_id Int?

  // Context (Where does this belong?)
  context    FileContext
  context_id String      @db.VarChar(128)

  // Cloudinary Data
  public_id     String // e.g., "peerspace/private/courses/101/homework_1"
  resource_type String // 'image', 'video', 'raw' (for PDFs/Docs)
  secure_url    String // The standard link
  format        String? // 'jpg', 'pdf', 'mp4'

  // Privacy Flag (Helps frontend know if it needs to ask for a signed link)
  is_private Boolean @default(false)

  created_at DateTime @default(now()) @db.Timestamp(6)

  // Relations
  User                      User?                      @relation("FileUploader", fields: [uploader_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  CommunityBanner           Community[]                @relation("CommunityBanner")
  UserAvatar                User[]                     @relation("UserAvatar")
  assignmentFileAttachments AssignmentFileAttachment[]
  noteFileAttachments       NoteFileAttachment[]
  postFileAttachments       PostFileAttachment[]
  submissionFileAttachments SubmissionFileAttachment[]

  @@index([context, context_id], name: "idx_file_context")
}

model Instructor {
  uid                 Int          @id
  title               String?      @db.VarChar
  area_of_expertise   String?      @db.VarChar
  google_scholar_link String?      @db.VarChar
  Assignment          Assignment[]
  User                User         @relation(fields: [uid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Manages             Manages[]
}

model Manages {
  iid        Int
  cid        String     @db.Uuid
  Community  Community  @relation(fields: [cid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Instructor Instructor @relation(fields: [iid], references: [uid], onDelete: Cascade, onUpdate: Cascade)

  @@id([iid, cid])
  @@index([iid])
  @@index([cid])
}

model Note {
  id                 Int                  @id @default(autoincrement())
  title              String               @db.VarChar
  body               String?              @db.VarChar
  created_at         DateTime             @db.Timestamp(6)
  updated_at         DateTime?            @db.Timestamp(6)
  owner_uid          Int
  notebook_id        Int?
  Notebook           Notebook?            @relation(fields: [notebook_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  User               User                 @relation(fields: [owner_uid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  NoteFileAttachment NoteFileAttachment[]
  PostNoteAttachment PostNoteAttachment[]

  @@index([owner_uid])
  @@index([notebook_id])
  @@index([created_at])
}

model NoteFileAttachment {
  nid  Int?
  fid  String @id @db.Uuid
  File File   @relation(fields: [fid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Note Note?  @relation(fields: [nid], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Notebook {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar
  description String?   @db.VarChar
  created_at  DateTime  @db.Timestamp(6)
  updated_at  DateTime? @db.Timestamp(6)
  owner_uid   Int
  Note        Note[]
  User        User      @relation(fields: [owner_uid], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([owner_uid])
}

// Normalized notification content model (shared details for a notification event)
model NotificationContent {
  id         Int              @id @default(autoincrement())
  message    String           @db.VarChar
  type       NotificationType
  resourceId String?          @db.VarChar
  createdAt  DateTime         @default(now()) @db.Timestamp(6)

  UserNotification UserNotification[]
}

// Relation model linking recipients to notification content with read-state
model UserNotification {
  id             Int     @id @default(autoincrement())
  notificationId Int
  recipientId    Int
  isRead         Boolean @default(false)

  Notification NotificationContent @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  recipient    User                @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId], name: "idx_usernotification_recipient")
  @@index([recipientId, isRead], name: "idx_usernotification_recipient_isRead")
}

model Post {
  id                 Int                  @id @default(autoincrement())
  title              String               @db.VarChar
  type               String               @db.VarChar
  post_date          DateTime             @db.Timestamp(6)
  body               String?              @db.VarChar
  is_resolved        Boolean?
  owner_uid          Int
  cid                String               @db.Uuid
  Comment            Comment[]
  Community          Community            @relation(fields: [cid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  User               User                 @relation(fields: [owner_uid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  PostFileAttachment PostFileAttachment[]
  PostNoteAttachment PostNoteAttachment[]
  PostTag            PostTag[]
  Voted              Voted[]

  @@index([cid])
  @@index([owner_uid])
  @@index([post_date])
  @@index([cid, post_date])
  @@index([title])
  @@index([type])
  @@index([post_date, id])
  @@index([is_resolved])
}

model PostFileAttachment {
  pid  Int?
  fid  String @id @db.Uuid
  File File   @relation(fields: [fid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Post Post?  @relation(fields: [pid], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([pid])
}

model PostNoteAttachment {
  pid  Int
  nid  Int
  Note Note @relation(fields: [nid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Post Post @relation(fields: [pid], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([pid, nid])
}

model PostTag {
  post_id Int
  tag     String @db.VarChar
  Post    Post   @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([post_id, tag])
  @@index([tag])
  @@index([post_id])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Session {
  cid        String    @id @db.Uuid
  title      String    @db.VarChar
  start_time DateTime  @db.Timestamp(6)
  meet_url   String    @db.VarChar
  Community  Community @relation(fields: [cid], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Student {
  uid           Int             @id
  Enrollment    Enrollment[]
  User          User            @relation(fields: [uid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  StudentBadge  StudentBadge[]
  Submission    Submission[]
  Task          Task[]
  TaskAssignees TaskAssignees[]
  Voted         Voted[]
}

model StudentBadge {
  sid     Int
  bid     Int
  Badge   Badge   @relation(fields: [bid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Student Student @relation(fields: [sid], references: [uid], onDelete: Cascade, onUpdate: Cascade)

  @@id([sid, bid])
  @@index([sid])
}

model Submission {
  id                       Int                        @id @default(autoincrement())
  subm_date                DateTime                   @db.Timestamp(6)
  grade                    Float?
  feedback                 String?                    @db.VarChar
  aid                      Int
  sid                      Int
  Assignment               Assignment                 @relation(fields: [aid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Student                  Student                    @relation(fields: [sid], references: [uid], onDelete: Cascade, onUpdate: Cascade)
  SubmissionFileAttachment SubmissionFileAttachment[]

  @@index([aid])
  @@index([sid])
  @@index([subm_date])
  @@index([sid, aid])
  @@index([sid, subm_date])
  @@index([sid, grade])
}

model SubmissionFileAttachment {
  subid      Int?
  fid        String      @id @db.Uuid
  File       File        @relation(fields: [fid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Submission Submission? @relation(fields: [subid], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Task {
  id                     Int                     @id @default(autoincrement())
  title                  String                  @db.VarChar
  description            String?                 @db.VarChar
  priority               Int?
  start_date             DateTime?               @db.Timestamp(6)
  end_date               DateTime?               @db.Timestamp(6)
  status                 Int
  author                 Int
  parent_task            Int?
  Student                Student                 @relation(fields: [author], references: [uid], onDelete: Cascade, onUpdate: Cascade)
  Task                   Task?                   @relation("TaskToTask", fields: [parent_task], references: [id], onDelete: Cascade, onUpdate: Cascade)
  other_Task             Task[]                  @relation("TaskToTask")
  TaskAssignees          TaskAssignees[]
  TaskAssignmentRelation TaskAssignmentRelation?
  TaskTag                TaskTag[]

  @@index([author])
  @@index([status])
  @@index([end_date])
  @@index([parent_task])
}

model TaskAssignees {
  tid        Int
  sid        Int
  isAccepted Boolean @default(false)
  Student    Student @relation(fields: [sid], references: [uid], onDelete: Cascade, onUpdate: Cascade)
  Task       Task    @relation(fields: [tid], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([tid, sid])
  @@index([sid])
  @@index([tid])
}

model TaskAssignmentRelation {
  aid        Int?
  tid        Int         @id
  Assignment Assignment? @relation(fields: [aid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Task       Task        @relation(fields: [tid], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model TaskTag {
  task_id Int
  tag     String @db.VarChar
  Task    Task   @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([task_id, tag])
}

model User {
  id             Int                @id @default(autoincrement())
  email          String             @unique @db.VarChar
  fname          String             @db.VarChar
  lname          String             @db.VarChar
  activated      Boolean            @default(true)
  hashedPassword String             @db.VarChar
  role           Role?              @default(STUDENT)
  token_hash     String?            @db.VarChar
  avatar_file_id String?            @db.Uuid
  ActivityLog    ActivityLog[]
  Admin          Admin?
  AvatarFile     File?              @relation("UserAvatar", fields: [avatar_file_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  Comment        Comment[]
  File           File[]             @relation("FileUploader")
  Instructor     Instructor?
  Note           Note[]
  Notebook       Notebook[]
  Post           Post[]
  Student        Student?
  Notification   UserNotification[]

  @@index([role])
  @@index([avatar_file_id])
}

model Voted {
  sid      Int
  pid      Int
  voteType Boolean
  Post     Post    @relation(fields: [pid], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Student  Student @relation(fields: [sid], references: [uid], onDelete: Cascade, onUpdate: Cascade)

  @@id([sid, pid])
  @@index([pid])
  @@index([sid])
  @@index([pid, voteType])
}
